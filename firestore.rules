rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Student Feedback Collection ---
    match /studentFeedback/{feedbackId} {
      // Students can create their own messages
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Students can read their own messages, admins can read all
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isSuperAdmin() ||
        resource.data.userId == request.auth.uid
      );
      
      // Only admins can update/delete messages
      allow update, delete: if isAuthenticated() && (isAdmin() || isSuperAdmin());

      match /replies/{replyId} {
        // Both students and admins can create replies
        allow create: if isAuthenticated();
        
        // Students can read replies to their own messages, admins can read all
        allow read: if isAuthenticated() && (
          isAdmin() || 
          isSuperAdmin() ||
          get(/databases/$(database)/documents/studentFeedback/$(feedbackId)).data.userId == request.auth.uid
        );
        
        // Only admins can update/delete replies
        allow update, delete: if isAuthenticated() && (isAdmin() || isSuperAdmin());
      }
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'isak@gmail.com';
    }

    function hasPermission(permission) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (isSuperAdmin() || 
         (isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[permission] == true));
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isUser(userId) || hasPermission('viewExaminers') || isAdmin();
      allow create: if isSuperAdmin() || hasPermission('addExaminers');
      allow update: if isUser(userId) || isSuperAdmin() || hasPermission('editExaminerPermissions');
      allow delete: if isSuperAdmin() || hasPermission('deleteExaminers');
    }

    // --- Exams Collection ---
    match /exams/{examId} {
      function isExamCreator() {
        return isAuthenticated() && resource.data.createdBy == request.auth.uid;
      }

      allow read: if isAuthenticated();
      allow create: if hasPermission('createExams') || (isAuthenticated() && request.resource.data.createdBy == request.auth.uid);
      allow update: if hasPermission('editAllExams') || (hasPermission('editOwnExams') && isExamCreator());
      allow delete: if hasPermission('deleteAllExams') || (hasPermission('deleteOwnExams') && isExamCreator());

      match /questions/{questionId} {
        function isParentExamCreator() {
          return isAuthenticated() && get(/databases/$(database)/documents/exams/$(examId)).data.createdBy == request.auth.uid;
        }
        allow read: if isAuthenticated();
        allow write: if hasPermission('editAllExams') || (hasPermission('editOwnExams') && isParentExamCreator());
      }

      match /blockedStudents/{studentId} {
        function isParentExamCreator() {
          return isAuthenticated() && get(/databases/$(database)/documents/exams/$(examId)).data.createdBy == request.auth.uid;
        }
        allow read: if isAuthenticated();
        allow write: if hasPermission('editAllExams') || (hasPermission('editOwnExams') && isParentExamCreator());
      }
    }

    // --- Exam Attempts Collection ---
    // UPDATED: Allow authenticated users to read all attempts (needed for leaderboard)
    match /examAttempts/{attemptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        function isAttemptOwner() {
          return get(/databases/$(database)/documents/examAttempts/$(attemptId)).data.studentId == request.auth.uid;
        }
        allow read: if isAuthenticated() && (isAttemptOwner() || isAdmin());
        allow write: if isAuthenticated() && (isAttemptOwner() || isAdmin());
      }
    }

    // --- Departments Collection ---
    match /departments/{departmentId} {
      allow read: if true;
      allow write: if hasPermission('manageDepartments');
    }

    // --- Leaderboard Collections (NEW) ---
    match /leaderboardCache/{departmentId} {
      allow read: if hasPermission('viewLeaderboard') || isAuthenticated();
      allow write: if hasPermission('manageLeaderboard');
    }

    match /leaderboardRankings/{rankingId} {
      allow read: if hasPermission('viewLeaderboard') || isAuthenticated();
      allow write: if hasPermission('manageLeaderboard');
    }
  }
}
